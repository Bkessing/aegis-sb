{
  "name": "aegis-sb",
  "version": "0.3.0",
  "description": "Supabase security guardian — audits a Supabase project for the security holes that ship by default when AI builds your app",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "aegis-sb": "dist/cli.js",
    "aegis-sb-mcp": "dist/mcp.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build",
    "start": "node dist/cli.js"
  },
  "files": [
    "dist",
    "skill",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "supabase",
    "security",
    "rls",
    "row-level-security",
    "audit",
    "scanner",
    "vibe-coding",
    "lovable",
    "bolt",
    "cursor",
    "claude-code",
    "mcp"
  ],
  "author": "Brandon Kessinger <Brandon@CardHabitApp.com> (https://x.com/KessingerBuilds)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Bkessing/aegis-sb.git"
  },
  "bugs": {
    "url": "https://github.com/Bkessing/aegis-sb/issues"
  },
  "homepage": "https://github.com/Bkessing/aegis-sb#readme",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "picocolors": "^1.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
